{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "activities-api",
      "urls": ["/api/activities", "/api/activities/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "12h",
        "timeout": "5s"
      }
    },
    {
      "name": "tramites-api",
      "urls": ["/api/tramites", "/api/tramites/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "12h",
        "timeout": "5s"
      }
    },
    {
      "name": "workflows-api",
      "urls": ["/api/workflows", "/api/workflows/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "24h",
        "timeout": "5s"
      }
    },
    {
      "name": "catalogs-api",
      "urls": [
        "/api/companies",
        "/api/departments",
        "/api/job-roles",
        "/api/users"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 30,
        "maxAge": "24h",
        "timeout": "5s"
      }
    }
  ]
}
